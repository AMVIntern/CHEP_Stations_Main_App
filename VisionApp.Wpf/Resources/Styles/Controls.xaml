<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Default window background -->
    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource PrimaryBackground}" />
    </Style>

    <!-- Header panel look (rounded, subtle background, accent border) -->
    <Style x:Key="HeaderPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBorder}" />
        <Setter Property="BorderThickness" Value="2.5" />
        <Setter Property="CornerRadius" Value="{StaticResource HeaderCornerRadius}" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- NavBar outer container border -->
    <Style x:Key="NavBarContainerBorderStyle"
       TargetType="Border"
       BasedOn="{StaticResource HeaderPanelBorderStyle}">

        <!-- these replace the local Border props in NavigationBar.xaml -->
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="Width" Value="{Binding NavBarWidth}"/>
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>

        <!-- Critical: when collapsed, reduce padding so arrow doesn’t get clipped -->
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                <Setter Property="Padding" Value="4"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Optional: a neutral panel border if you don't want accent everywhere -->
    <Style x:Key="NeutralPanelBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource NeutralBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource HeaderCornerRadius}" />
        <Setter Property="Padding" Value="10" />
    </Style>

    <!-- =========================================================
     NAV BAR STYLES
     ========================================================= -->

    <!-- Arrow button (collapse/expand) -->
    <Style x:Key="NavArrowButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="52"/>
        <Setter Property="Height" Value="52"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource NeutralBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Focusable" Value="False"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="14">

                        <!-- Arrow lives INSIDE template so we can style it -->
                        <Path x:Name="ArrowPath"
                          Data="M 0 0 L 10 10 L 0 20"
                          Stroke="{DynamicResource PrimaryForeground}"
                          StrokeThickness="3"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          RenderTransformOrigin="0.5,0.5"/>

                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Just accent border + accent arrow -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            <!-- Optional *very subtle* accent tint. If you want zero fill, keep Transparent -->
                            <Setter TargetName="Bd" Property="Background" Value="#3319C7C2"/>
                            <Setter TargetName="ArrowPath" Property="Stroke" Value="{DynamicResource AccentBorderBrush}"/>
                        </Trigger>

                        <!-- Pressed: slightly stronger tint -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#3319C7C2"/>
                        </Trigger>

                        <!-- Rotation based on IsCollapsed (needs VM binding) -->
                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                            <Setter TargetName="ArrowPath" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="180"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>

                        <DataTrigger Binding="{Binding IsCollapsed}" Value="False">
                            <Setter TargetName="ArrowPath" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="0"/>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- Main navigation button (Home / Image Logs / Exit) -->
    <Style x:Key="NavMenuButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="130"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="30"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="TextBlock.TextAlignment" Value="Center"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="12">
                        <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="Bd" Property="Background" Value="#18212C"/>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#101821"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Close button (X) for ImageDetailWindow -->
    <Style x:Key="WindowCloseButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="60"/>
        <Setter Property="Height" Value="60"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="{DynamicResource NeutralBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">

                        <!-- Big X -->
                        <TextBlock x:Name="CloseGlyph"
                               Text="✕"
                               Foreground="{DynamicResource PrimaryForeground}"
                               FontSize="26"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- Hover: accent border + subtle tint -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBorderBrush}"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="Bd" Property="Background" Value="#3319C7C2"/>
                        </Trigger>

                        <!-- Pressed: a touch stronger tint -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#3319C7C2"/>
                        </Trigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


</ResourceDictionary>