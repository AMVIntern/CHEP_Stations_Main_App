<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- =========================
         COLORS (tokens)
         ========================= -->
    <Color x:Key="AppBackgroundColor">#0F1115</Color>
    <Color x:Key="PanelBackgroundColor">#141822</Color>
    <Color x:Key="HeaderBackgroundColor">#101522</Color>

    <!-- Accent (teal). You can change later to CHEP blue easily -->
    <Color x:Key="AccentColor">#14A79D</Color>

    <Color x:Key="TextPrimaryColor">#E8EEF6</Color>
    <Color x:Key="TextSecondaryColor">#98A6B8</Color>

    <Color x:Key="BorderColor">#2A3242</Color>

    <!-- =========================
         BRUSHES (use these in UI)
         ========================= -->
    <SolidColorBrush x:Key="PrimaryBackground" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="{StaticResource HeaderBackgroundColor}" />

    <SolidColorBrush x:Key="PrimaryBorder" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="NeutralBorderBrush" Color="{StaticResource BorderColor}" />

    <SolidColorBrush x:Key="PrimaryForeground" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="SecondaryForeground" Color="{StaticResource TextSecondaryColor}" />

    <SolidColorBrush x:Key="AccentBorderBrush" Color="{StaticResource AccentColor}" />

    <!-- Common radii -->
    <CornerRadius x:Key="HeaderCornerRadius">14</CornerRadius>
</ResourceDictionary>