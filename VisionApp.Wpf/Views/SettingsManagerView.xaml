<UserControl x:Class="VisionApp.Wpf.Views.SettingsManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
     <Grid Background="{DynamicResource PrimaryBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel Margin="0,0,0,20">
                <!-- Title -->
                <TextBlock Text="Confidence Score Settings"
                           FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryForeground}"/>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource AccentBorderBrush}" TextWrapping="Wrap"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Station 4 Settings -->
                <GroupBox Header="Side Station" Padding="15" BorderThickness="1" BorderBrush="{DynamicResource NeutralBorderBrush}" Background="{DynamicResource PanelBackgroundBrush}" Foreground="{DynamicResource PrimaryForeground}">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Station4Classes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Class Name -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryForeground}"/>

                                        <!-- Slider -->
                                        <Slider Grid.Column="1"
                                                Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.1"
                                                Value="{Binding Threshold, Mode=TwoWay}"
                                                VerticalAlignment="Center" Margin="15,0,0,0"/>

                                        <!-- Numeric Input -->
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding Threshold, StringFormat=0.000, Mode=TwoWay}"
                                                 Padding="8" FontSize="12" TextAlignment="Right" Margin="15,0,0,0"
                                                 Background="{DynamicResource PanelBackgroundBrush}" Foreground="{DynamicResource PrimaryForeground}"
                                                 BorderBrush="{DynamicResource NeutralBorderBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>

                <!-- Station 5 Settings -->
                <GroupBox Header="Bottom Station" Padding="15" BorderThickness="1" BorderBrush="{DynamicResource NeutralBorderBrush}" Background="{DynamicResource PanelBackgroundBrush}" Foreground="{DynamicResource PrimaryForeground}">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Station5Classes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Class Name -->
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryForeground}"/>

                                        <!-- Slider -->
                                        <Slider Grid.Column="1"
                                                Minimum="0" Maximum="1" SmallChange="0.01" LargeChange="0.1"
                                                Value="{Binding Threshold, Mode=TwoWay}"
                                                VerticalAlignment="Center" Margin="15,0,0,0"/>

                                        <!-- Numeric Input -->
                                        <TextBox Grid.Column="2"
                                                 Text="{Binding Threshold, StringFormat=0.000, Mode=TwoWay}"
                                                 Padding="8" FontSize="12" TextAlignment="Right" Margin="15,0,0,0"
                                                 Background="{DynamicResource PanelBackgroundBrush}" Foreground="{DynamicResource PrimaryForeground}"
                                                 BorderBrush="{DynamicResource NeutralBorderBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Command="{Binding SaveCommand}"
                            Padding="15,10" FontSize="13" FontWeight="SemiBold"
                            Background="{DynamicResource AccentBorderBrush}" Foreground="{DynamicResource PrimaryBackground}"
                            BorderThickness="0">
                        Save Changes
                    </Button>
                    <Button Command="{Binding ResetCommand}"
                            Padding="15,10" FontSize="13" Margin="10,0,0,0"
                            Background="{DynamicResource PanelBackgroundBrush}" Foreground="{DynamicResource PrimaryForeground}"
                            BorderThickness="1" BorderBrush="{DynamicResource NeutralBorderBrush}">
                        Reset
                    </Button>
                </StackPanel>

                <TextBlock Text="Note: Changes are saved to the configuration file and will take effect on the next inspection cycle."
                           FontSize="11" Foreground="{DynamicResource SecondaryForeground}" TextWrapping="Wrap" Margin="0,20,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
