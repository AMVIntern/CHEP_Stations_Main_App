<UserControl x:Class="VisionApp.Wpf.Views.SettingsManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">
    <UserControl.Resources>
        <Style x:Key="ThresholdLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ThresholdSliderStyle" TargetType="Slider">
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="SmallChange" Value="0.01"/>
            <Setter Property="LargeChange" Value="0.1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ThresholdBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource NeutralBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="120"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource PrimaryBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Confidence Score Settings"
                           FontSize="44"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Adjust per-class confidence thresholds. Changes are saved to the configuration file."
                           FontSize="18"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource SecondaryForeground}"/>

                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource AccentBorderBrush}"
                           FontSize="16"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <GroupBox Header="Side Station"
                          Margin="0,20,0,0"
                          Padding="16"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource NeutralBorderBrush}"
                          Background="{DynamicResource PanelBackgroundBrush}"
                          Foreground="White"
                          HorizontalContentAlignment="Stretch">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Station4Classes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="320"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   Style="{StaticResource ThresholdLabelStyle}"/>

                                        <Slider Grid.Column="1"
                                                Margin="24,0,24,0"
                                                Style="{StaticResource ThresholdSliderStyle}"
                                                Value="{Binding Threshold, Mode=TwoWay}"/>

                                        <TextBox Grid.Column="2"
                                                 Style="{StaticResource ThresholdBoxStyle}"
                                                 Text="{Binding Threshold, StringFormat=0.000, Mode=TwoWay}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="Bottom Station"
                          Margin="0,16,0,0"
                          Padding="16"
                          BorderThickness="1"
                          BorderBrush="{DynamicResource NeutralBorderBrush}"
                          Background="{DynamicResource PanelBackgroundBrush}"
                          Foreground="White"
                          HorizontalContentAlignment="Stretch">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding Station5Classes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="320"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding DisplayName}"
                                                   Style="{StaticResource ThresholdLabelStyle}"/>

                                        <Slider Grid.Column="1"
                                                Margin="24,0,24,0"
                                                Style="{StaticResource ThresholdSliderStyle}"
                                                Value="{Binding Threshold, Mode=TwoWay}"/>

                                        <TextBox Grid.Column="2"
                                                 Style="{StaticResource ThresholdBoxStyle}"
                                                 Text="{Binding Threshold, StringFormat=0.000, Mode=TwoWay}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </GroupBox>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,20,0,0">
                    <Button Command="{Binding SaveCommand}"
                            Padding="32,12"
                            FontSize="22"
                            FontWeight="Bold"
                            Background="{DynamicResource AccentBorderBrush}"
                            Foreground="{DynamicResource PrimaryBackground}"
                            BorderThickness="0">
                        Save Changes
                    </Button>
                    <Button Command="{Binding ResetCommand}"
                            Padding="32,12"
                            FontSize="22"
                            FontWeight="Bold"
                            Margin="16,0,0,0"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            Foreground="White"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource AccentBorderBrush}">
                        Reset
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
