<Window x:Class="VisionApp.Wpf.Views.ImageDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:halcon="http://schemas.mvtec.com/halcondotnet"
        Title="Image Detail"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource PrimaryBackground}"
        WindowStyle="None"
        ResizeMode="CanResize"
        AllowsTransparency="False">


    <!-- IMPORTANT: margin on the root so nothing touches window edge -->
    <Grid Margin="16">

        <!-- Whole window panel frame -->
        <Border Style="{StaticResource HeaderPanelBorderStyle}"
                Background="{DynamicResource PanelBackgroundBrush}"
                Padding="14">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Title}"
                   FontWeight="SemiBold"
                   FontSize="16"
                   Foreground="{DynamicResource PrimaryForeground}"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                       Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Margin="12,0,12,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource SecondaryForeground}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Pass}" Value="True">
                                        <Setter Property="Foreground" Value="#00D46A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Pass}" Value="False">
                                        <Setter Property="Foreground" Value="#FF2D2D"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Close button (X in a box) -->
                    <Button Grid.Column="2"
                    Style="{StaticResource WindowCloseButtonStyle}"
                    Click="OnBackClick"/>

                </Grid>

                <!-- Image area -->

                <Grid Grid.Row="1"
                  x:Name="ImageHost"
                  Background="{DynamicResource PanelBackgroundBrush}"
                  ClipToBounds="True">

                    <!-- Square container that fits inside available HEIGHT -->
                    <Border Width="{Binding ActualHeight, ElementName=ImageHost}"
                        Height="{Binding ActualHeight, ElementName=ImageHost}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        CornerRadius="8"
                        Background="{DynamicResource PanelBackgroundBrush}">

                        <!-- PASS/FAIL border around the image -->
                        <!-- PASS/FAIL border around the image (Rectangle overlay so FAIL can be dotted) -->
                        <Border CornerRadius="8"
        Padding="6"
        ClipToBounds="True"
        Background="{DynamicResource PanelBackgroundBrush}">

                            <Grid>
                                <!-- HALCON viewer -->
                                <halcon:HSmartWindowControlWPF x:Name="SmartWin"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"/>

                                <!-- PASS/FAIL outline -->
                                <Rectangle RadiusX="8"
                                   RadiusY="8"
                                   Fill="Transparent"
                                   StrokeThickness="3"
                                   StrokeLineJoin="Round"
                                   IsHitTestVisible="False">
                                    <Rectangle.Style>
                                        <Style TargetType="Rectangle">
                                            <!-- default / neutral -->
                                            <Setter Property="Stroke" Value="{DynamicResource NeutralBorderBrush}"/>
                                            <Setter Property="StrokeDashArray" Value="{x:Null}"/>
                                            <Setter Property="StrokeDashCap" Value="Round"/>

                                            <Style.Triggers>
                                                <!-- PASS = solid neon green -->
                                                <DataTrigger Binding="{Binding Pass}" Value="True">
                                                    <Setter Property="Stroke" Value="#00D46A"/>
                                                    <Setter Property="StrokeDashArray" Value="{x:Null}"/>
                                                </DataTrigger>

                                                <!-- FAIL = dotted red (bigger blocks like your example) -->
                                                <DataTrigger Binding="{Binding Pass}" Value="False">
                                                    <Setter Property="Stroke" Value="#FF2D2D"/>
                                                    <Setter Property="StrokeDashArray" Value="12 8"/>
                                                    <Setter Property="StrokeDashCap" Value="Square"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Rectangle.Style>
                                </Rectangle>
                            </Grid>
                        </Border>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
