<UserControl x:Class="VisionApp.Wpf.UserControls.NavigationBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d">

    <Border Style="{StaticResource NavBarContainerBorderStyle}"
            Background="{DynamicResource PanelBackgroundBrush}"
            Width="{Binding NavBarWidth}"
            Margin="10"
            SnapsToDevicePixels="True"
            ClipToBounds="True">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- toggle -->
                <RowDefinition Height="Auto"/>
                <!-- buttons -->
                <RowDefinition Height="*"/>
                <!-- filler -->
            </Grid.RowDefinitions>

            <!-- Toggle arrow (always visible) -->
            <Button Grid.Row="0"
                    Style="{StaticResource NavArrowButtonStyle}"
                    Command="{Binding ToggleNavigationBarCommand}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="10,10,10,20">

                <Path Stroke="{DynamicResource PrimaryForeground}"
                      StrokeThickness="3"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Data="M 0 0 L 10 10 L 0 20"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">
                    <Path.Style>
                        <Style TargetType="Path">
                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>

                            <!-- Collapsed: point LEFT -->
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="180"/>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <!-- Expanded: point RIGHT -->
                                <DataTrigger Binding="{Binding IsCollapsed}" Value="False">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="0"/>
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
            </Button>

            <!-- Nav buttons (top aligned) -->
            <StackPanel Grid.Row="1"
                        Margin="10,0,10,10"
                        VerticalAlignment="Top">

                <!-- HOME -->
                <Button Style="{StaticResource NavMenuButtonStyle}"
                        Command="{Binding HomeCommand}">
                    <Grid>
                        <!-- Icon only (collapsed) -->
                        <md:PackIcon Kind="HomeOutline"
                                     Width="22" Height="22"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                            <md:PackIcon.Style>
                                <Style TargetType="md:PackIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </md:PackIcon.Style>
                        </md:PackIcon>

                        <!-- Text only (expanded) -->
                        <TextBlock Text="Home"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Button>

                <!-- IMAGE LOGS -->
                <Button Style="{StaticResource NavMenuButtonStyle}"
                        Command="{Binding OpenImageLogsCommand}">
                    <Grid>
                        <!-- Icon only (collapsed) -->
                        <md:PackIcon Kind="FolderMultipleImage"
                                     Width="22" Height="22"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                            <md:PackIcon.Style>
                                <Style TargetType="md:PackIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </md:PackIcon.Style>
                        </md:PackIcon>

                        <!-- Text only (expanded) -->
                        <TextBlock Text="Image&#x0A;Logs"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Button>

                <!-- SETTINGS -->
                <Button Style="{StaticResource NavMenuButtonStyle}"
                        Command="{Binding SettingsCommand}">
                    <Grid>
                        <!-- Icon only (collapsed) -->
                        <md:PackIcon Kind="CogOutline"
                                     Width="22" Height="22"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                            <md:PackIcon.Style>
                                <Style TargetType="md:PackIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </md:PackIcon.Style>
                        </md:PackIcon>

                        <!-- Text only (expanded) -->
                        <TextBlock Text="Settings"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Button>

                <!-- EXIT -->
                <Button Style="{StaticResource NavMenuButtonStyle}"                       
                        Command="{Binding ExitAppCommand}">
                    <Grid>
                        <!-- Icon only (collapsed) -->
                        <md:PackIcon Kind="Logout"
                                     Width="22" Height="22"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center">
                            <md:PackIcon.Style>
                                <Style TargetType="md:PackIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </md:PackIcon.Style>
                        </md:PackIcon>

                        <!-- Text only (expanded) -->
                        <TextBlock Text="Exit"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCollapsed}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Button>

            </StackPanel>

        </Grid>
    </Border>
</UserControl>
