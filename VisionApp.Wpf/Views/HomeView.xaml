<UserControl x:Class="VisionApp.Wpf.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Station Headers Row -->
        <Grid Grid.Row="0" Background="{DynamicResource PanelBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding StationHeaders[0].StarWidth}"/>
                <ColumnDefinition Width="{Binding StationHeaders[1].StarWidth}"/>
            </Grid.ColumnDefinitions>

            <!-- Station 4 Header -->
            <Border Grid.Column="0"
                    Margin="8,4"
                    Padding="10,4"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    CornerRadius="4">
                <TextBlock Text="{Binding StationHeaders[0].DisplayName}"
                           Foreground="{DynamicResource PrimaryForeground}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Station 5 Header -->
            <Border Grid.Column="1"
                    Margin="8,4"
                    Padding="10,4"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource AccentBorderBrush}"
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    CornerRadius="4">
                <TextBlock Text="{Binding StationHeaders[1].DisplayName}"
                           Foreground="{DynamicResource PrimaryForeground}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Camera Groups Row -->
        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding CameraGroups}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <!-- One row, N columns -->
                    <UniformGrid Rows="1"
                                 Columns="{Binding CameraGroupColumns}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                    <Setter Property="VerticalAlignment" Value="Stretch"/>
                </Style>
            </ItemsControl.ItemContainerStyle>

        </ItemsControl>
    </Grid>

</UserControl>
