<Application x:Class="VisionApp.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>
        <ResourceDictionary>

            <!-- Global default styles -->
            <Style TargetType="{x:Type FrameworkElement}">
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
            </Style>

            <Style TargetType="{x:Type Control}">
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="UseLayoutRounding" Value="True"/>
            </Style>

            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Theme.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Typography.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Controls.xaml"/>
                <ResourceDictionary Source="Resources/Styles/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>

        </ResourceDictionary>
    </Application.Resources>
</Application>
