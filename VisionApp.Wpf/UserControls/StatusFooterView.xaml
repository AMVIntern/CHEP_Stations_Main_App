<UserControl x:Class="VisionApp.Wpf.UserControls.StatusFooterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:VisionApp.Wpf.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="44"
             d:DesignWidth="1024">

    <Border Background="{DynamicResource HeaderBackgroundBrush}"
            Padding="12,8"
            BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource NeutralBorderBrush}">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Camera connection status -->
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <!-- Status dot -->
                <Ellipse Width="10"
                         Height="10"
                         Margin="0,0,10,0"
                         Stroke="#111"
                         StrokeThickness="1">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <!-- default -->
                            <Setter Property="Fill" Value="#F6C343"/>
                            <!-- yellow -->
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OverallState}" Value="{x:Static vm:FooterConnectionState.Ready}">
                                    <Setter Property="Fill" Value="#00E676"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding OverallState}" Value="{x:Static vm:FooterConnectionState.Reconnecting}">
                                    <Setter Property="Fill" Value="#F6C343"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding OverallState}" Value="{x:Static vm:FooterConnectionState.Disconnected}">
                                    <Setter Property="Fill" Value="#E7040F"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>

                <!-- Status text -->
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource PrimaryForeground}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- RIGHT: Production metrics (Shift, Total, Assured, Standard) -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="0,0,4,0">

                <TextBlock Foreground="{DynamicResource PrimaryForeground}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    <Run Text="Shift: "/>
                    <Run Text="{Binding ShiftNumber, Mode=OneWay}"/>
                </TextBlock>

                <TextBlock Text="  |  "
                           Foreground="{DynamicResource PrimaryForeground}"
                           VerticalAlignment="Center"/>

                <TextBlock Foreground="{DynamicResource PrimaryForeground}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    <Run Text="Total: "/>
                    <Run Text="{Binding Total, Mode=OneWay}"/>
                </TextBlock>

                <TextBlock Text="  |  "
                           Foreground="{DynamicResource PrimaryForeground}"
                           VerticalAlignment="Center"/>

                <TextBlock Foreground="#0037FF"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    <Run Text="NIL Defect: "/>
                    <Run Text="{Binding Assured, Mode=OneWay}"/>
                </TextBlock>

                <!-- <TextBlock Text="  |  "
                           Foreground="{DynamicResource PrimaryForeground}"
                           VerticalAlignment="Center"/>

                <TextBlock Foreground="#AAACB1"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    <Run Text="Standard: "/>
                    <Run Text="{Binding Standard, Mode=OneWay}"/>
                </TextBlock> -->

            </StackPanel>
        </Grid>
    </Border>
</UserControl>
