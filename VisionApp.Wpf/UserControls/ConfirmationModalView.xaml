<UserControl x:Class="VisionApp.Wpf.UserControls.ConfirmationModalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource AccentBorderBrush}"
            BorderThickness="2"
            CornerRadius="18"
            Padding="32"
            Width="640">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Title}"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryForeground}"
                       TextAlignment="Center"/>

            <TextBlock Grid.Row="2"
                       Text="{Binding Message}"
                       FontSize="22"
                       Foreground="{DynamicResource SecondaryForeground}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"/>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="Ok"
                        Width="200"
                        Height="100"
                        Margin="0,0,18,0"
                        Style="{StaticResource NavMenuButtonStyle}"
                        Command="{Binding OkCommand}"/>

                <Button Content="Cancel"
                        Width="200"
                        Height="100"
                        Margin="0"
                        Style="{StaticResource NavMenuButtonStyle}"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
