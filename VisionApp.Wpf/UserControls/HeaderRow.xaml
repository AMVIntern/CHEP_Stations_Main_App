<UserControl x:Class="VisionApp.Wpf.UserControls.HeaderRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:VisionApp.Wpf.UserControls"
             xmlns:sc="clr-namespace:VisionApp.Wpf.UserControls.SubControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!-- Header row -->
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Add spacing by using Margin on each box -->
        <sc:AMVLogo Grid.Column="0"                   
                    Margin="0,0,12,0"/>

        <sc:Title Grid.Column="1"                  
                  Margin="0,0,12,0"/>

        <sc:CustomerLogo Grid.Column="2"/>
    </Grid>
</UserControl>
