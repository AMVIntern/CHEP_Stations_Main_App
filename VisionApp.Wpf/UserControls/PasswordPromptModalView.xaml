<UserControl x:Class="VisionApp.Wpf.UserControls.PasswordPromptModalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource AccentBorderBrush}"
            BorderThickness="2"
            CornerRadius="18"
            Padding="32"
            Width="640">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding Title}"
                       FontSize="32"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource PrimaryForeground}"
                       TextAlignment="Center"/>

            <TextBlock Grid.Row="2"
                       Text="Enter password"
                       FontSize="22"
                       Foreground="{DynamicResource SecondaryForeground}"
                       TextAlignment="Center"/>

            <PasswordBox x:Name="PwdBox"
                         Grid.Row="4"
                         Height="48"
                         FontSize="20"
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,0"
                         PasswordChanged="PwdBox_OnPasswordChanged"
                         KeyDown="PwdBox_OnKeyDown"/>

            <TextBlock Grid.Row="6"
                       Text="{Binding ErrorMessage}"
                       FontSize="18"
                       Foreground="#E7040F"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

            <StackPanel Grid.Row="8"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center">

                <Button Content="OK"
                        Width="200"
                        Height="100"
                        Margin="0,0,18,0"
                        Style="{StaticResource NavMenuButtonStyle}"
                        Command="{Binding SubmitCommand}"/>

                <Button Content="Cancel"
                        Width="200"
                        Height="100"
                        Margin="0"
                        Style="{StaticResource NavMenuButtonStyle}"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
